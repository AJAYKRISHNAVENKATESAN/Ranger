    <link name="base_link">
      <inertial>
        <origin xyz="0.0037260211530280884 -5.630419889232648e-17 0.04338922715226838" rpy="0 0 0"/>
        <mass value="20.28845748451776"/>
        <inertia ixx="0.071889" iyy="0.07529" izz="0.129659" ixy="-0.0" iyz="-0.0" ixz="-0.003176"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ranger/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ranger/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <link name="right_wheel_link_1">
      <inertial>
        <origin xyz="7.972789095589405e-15 -0.015000000000000041 7.355227538141662e-15" rpy="0 0 0"/>
        <mass value="1.165255985124623"/>
        <inertia ixx="0.000561" iyy="0.000947" izz="0.000561" ixy="-0.0" iyz="-0.0" ixz="0.0"/>
      </inertial>
      <visual>
        <origin xyz="0.055 0.1025 -0.04" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ranger/meshes/right_wheel_link_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <origin xyz="0.055 0.1025 -0.04" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ranger/meshes/right_wheel_link_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <link name="left_wheel_link_1">
      <inertial>
        <origin xyz="9.228728892196614e-15 0.015000000000000027 6.279698983036042e-15" rpy="0 0 0"/>
        <mass value="1.165255985124623"/>
        <inertia ixx="0.000561" iyy="0.000947" izz="0.000561" ixy="-0.0" iyz="0.0" ixz="0.0"/>
      </inertial>
      <visual>
        <origin xyz="0.055 -0.1025 -0.04" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ranger/meshes/left_wheel_link_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <origin xyz="0.055 -0.1025 -0.04" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ranger/meshes/left_wheel_link_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <link name="lidar_link_1">
      <inertial>
        <origin xyz="0.0 0.0 0.015000000000000027" rpy="0 0 0"/>
        <mass value="1.183752111872634"/>
        <inertia ixx="0.000562" iyy="0.000562" izz="0.000947" ixy="-0.0" iyz="0.0" ixz="0.0"/>
      </inertial>
      <visual>
        <origin xyz="-0.05 -0.0 -0.105" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ranger/meshes/lidar_link_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <origin xyz="-0.05 -0.0 -0.105" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ranger/meshes/lidar_link_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <joint name="right_wheel_joint" type="continuous">
      <origin xyz="-0.055 -0.1025 0.04" rpy="0 0 0"/>
      <parent link="base_link"/>
      <child link="right_wheel_link_1"/>
      <axis xyz="0.0 1.0 0.0"/>
    </joint>

    <joint name="left_wheel_joint" type="continuous">
      <origin xyz="-0.055 0.1025 0.04" rpy="0 0 0"/>
      <parent link="base_link"/>
      <child link="left_wheel_link_1"/>
      <axis xyz="0.0 1.0 0.0"/>
    </joint>

    <joint name="lidar_joint" type="fixed">
      <origin xyz="0.05 0.0 0.115" rpy="0 0 0"/>
      <parent link="base_link"/>
      <child link="lidar_link_1"/>
    </joint>

            <ros2_control name="DiffDriveSystem" type="system">
              <hardware>
                <plugin>ign_ros2_control/IgnitionSystem</plugin> 
              <!-- <plugin>gz_ros2_control/GazeboSimSystem</plugin> -->
              </hardware>

              <joint name="left_wheel_joint">
                <command_interface name="velocity"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
              </joint>

              <joint name="right_wheel_joint">
                <command_interface name="velocity"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
              </joint>   
            </ros2_control>

